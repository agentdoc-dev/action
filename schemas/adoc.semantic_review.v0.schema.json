{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agentdoc-dev/action/schemas/adoc.semantic_review.v0.schema.json",
  "title": "AgentDoc Cited Semantic Review",
  "oneOf": [
    { "$ref": "#/$defs/complete" },
    { "$ref": "#/$defs/incomplete" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "objectRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "content_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "content_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "hunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "old_range", "new_range", "sha256", "truncated"],
      "properties": {
        "id": { "type": "string", "pattern": "^hunk-[0-9]{3,}$" },
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "old_range": { "type": "string", "pattern": "^[0-9]+,[0-9]+$" },
        "new_range": { "type": "string", "pattern": "^[0-9]+,[0-9]+$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "truncated": { "type": "boolean" }
      }
    },
    "knowledgeContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "content_hash", "body_bytes"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "content_hash": { "$ref": "#/$defs/sha256" },
        "body_bytes": { "type": "integer", "minimum": 0, "maximum": 16384 }
      }
    },
    "lexicalQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "query_sha256", "top_k", "results"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "query_sha256": { "$ref": "#/$defs/sha256" },
        "top_k": { "const": 5 },
        "results": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/objectRef" }
        }
      }
    },
    "lexicalProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "index_revision", "graph_sha256", "adoc_version", "adoc_binary_sha256", "top_k", "query_manifest_sha256", "queries"],
      "properties": {
        "mode": { "const": "graph_derived_bm25" },
        "index_revision": { "const": "bm25-v1" },
        "graph_sha256": { "$ref": "#/$defs/sha256" },
        "adoc_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "adoc_binary_sha256": { "$ref": "#/$defs/sha256" },
        "top_k": { "const": 5 },
        "query_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "queries": {
          "type": "array",
          "items": { "$ref": "#/$defs/lexicalQuery" }
        }
      }
    },
    "codeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "hunk_id", "old_range", "new_range", "hunk_sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "hunk_id": { "type": "string", "pattern": "^hunk-[0-9]{3,}$" },
        "old_range": { "type": "string", "pattern": "^[0-9]+,[0-9]+$" },
        "new_range": { "type": "string", "pattern": "^[0-9]+,[0-9]+$" },
        "hunk_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "classification", "code_evidence", "knowledge_evidence", "rationale", "proposal_expected"],
      "properties": {
        "finding_id": { "type": "string", "pattern": "^finding-[0-9]{3,}$" },
        "classification": {
          "enum": [
            "consistent",
            "extends_existing_knowledge",
            "contradicts_existing_knowledge",
            "insufficient_evidence"
          ]
        },
        "code_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/codeEvidence" }
        },
        "knowledge_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/objectRef" }
        },
        "rationale": { "type": "string", "maxLength": 1000 },
        "proposal_expected": { "type": "boolean" }
      }
    },
    "base": {
      "type": "object",
      "required": ["schema_version", "status", "diagnostics"],
      "properties": {
        "schema_version": { "const": "adoc.semantic_review.v0" },
        "status": { "enum": ["complete", "skipped", "partial", "error"] },
        "diagnostics": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 256 }
        }
      }
    },
    "complete": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "status", "assessment_sha256", "revisions", "bounded_diff", "input_context", "provider", "findings", "diagnostics"],
          "properties": {
            "schema_version": { "const": "adoc.semantic_review.v0" },
            "status": { "const": "complete" },
            "assessment_sha256": { "$ref": "#/$defs/sha256" },
            "revisions": {
              "type": "object",
              "additionalProperties": false,
              "required": ["comparison_base", "head"],
              "properties": {
                "comparison_base": { "$ref": "#/$defs/commit" },
                "head": { "$ref": "#/$defs/commit" }
              }
            },
            "bounded_diff": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sha256", "bytes", "selected_paths", "omitted_paths", "selected_hunks", "omitted_hunks", "truncated"],
              "properties": {
                "sha256": { "$ref": "#/$defs/sha256" },
                "bytes": { "type": "integer", "minimum": 0, "maximum": 262144 },
                "selected_paths": { "type": "integer", "minimum": 0, "maximum": 50 },
                "omitted_paths": { "type": "integer", "minimum": 0 },
                "selected_hunks": { "type": "integer", "minimum": 0, "maximum": 1000 },
                "omitted_hunks": { "type": "integer", "minimum": 0 },
                "truncated": { "type": "boolean" }
              }
            },
            "input_context": {
              "type": "object",
              "additionalProperties": false,
              "required": ["graph_sha256", "object_set_sha256", "knowledge_selection", "lexical_projection", "code_hunks", "knowledge_objects"],
              "properties": {
                "graph_sha256": { "$ref": "#/$defs/sha256" },
                "object_set_sha256": { "$ref": "#/$defs/sha256" },
                "knowledge_selection": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["selected_objects", "omitted_objects", "truncated"],
                  "properties": {
                    "selected_objects": { "type": "integer", "minimum": 0, "maximum": 50 },
                    "omitted_objects": { "type": "integer", "minimum": 0 },
                    "truncated": { "type": "boolean" }
                  }
                },
                "lexical_projection": { "$ref": "#/$defs/lexicalProjection" },
                "code_hunks": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/hunk" }
                },
                "knowledge_objects": {
                  "type": "array",
                  "maxItems": 50,
                  "items": { "$ref": "#/$defs/knowledgeContext" }
                }
              }
            },
            "provider": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "model", "provider_version", "package_integrity", "prompt_revision"],
              "properties": {
                "name": { "const": "claude-code" },
                "model": { "type": "string", "pattern": "^[A-Za-z0-9._@+-]{1,128}$" },
                "provider_version": { "type": "string", "pattern": "^[A-Za-z0-9._@+-]{1,128}$" },
                "package_integrity": { "type": "string", "pattern": "^sha512:[0-9a-f]{128}$" },
                "prompt_revision": { "$ref": "#/$defs/sha256" }
              }
            },
            "findings": {
              "type": "array",
              "maxItems": 100,
              "items": { "$ref": "#/$defs/finding" }
            },
            "diagnostics": {
              "type": "array",
              "maxItems": 20,
              "items": { "type": "string", "maxLength": 256 }
            }
          }
        }
      ]
    },
    "incomplete": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "status", "diagnostics"],
          "properties": {
            "schema_version": { "const": "adoc.semantic_review.v0" },
            "status": { "enum": ["skipped", "partial", "error"] },
            "diagnostics": {
              "type": "array",
              "maxItems": 20,
              "items": { "type": "string", "maxLength": 256 }
            }
          }
        }
      ]
    }
  }
}
